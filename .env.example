# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gmail SMTP (use an App Password, not your main password)
GMAIL_USER=facebook.asim159@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Lead notification recipient
LEAD_NOTIFY_EMAIL=facebook.asim159@gmail.com

# Server
PORT=3000
NODE_ENV=production

# CORS — set to your Netlify domain
ALLOWED_ORIGIN=https://aerozag.netlify.app

# Admin token for GET /api/leads
ADMIN_TOKEN=change_me_to_a_long_random_secret

# SQLite DB path (Railway persistent volume mount at /data)
DB_PATH=/data/aerozag.db
